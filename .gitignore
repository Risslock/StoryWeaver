# =============================================================================
# StoryWeaver — .gitignore
# Stack: Python 3.11+, uv, pytest, ruff, pyright, Gradio, Docker, SQLite,
#        ChromaDB, Ollama, ComfyUI/SD image gen
# =============================================================================

# --- Python bytecode ----------------------------------------------------------
__pycache__/
*.py[codz]
*$py.class

# C extensions (permitted for performance-critical paths per constitution)
*.so

# --- Build & packaging --------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
sdist/
develop-eggs/
share/python-wheels/
.installed.cfg

# --- Virtual environments -----------------------------------------------------
.venv
venv/
env/
env.bak/
venv.bak/
ENV/
.Python

# uv — commit uv.lock for reproducible installs (app, not library)
# Uncomment only if you intentionally want to omit the lock file:
# uv.lock

# --- Environment & secrets ----------------------------------------------------
.env
.env.local
.env.*.local
.envrc
# .env.example is intentionally committed as a template

# --- Testing & coverage -------------------------------------------------------
.pytest_cache/
.hypothesis/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.py.cover
nosetests.xml

# --- Linting & type checking --------------------------------------------------
.ruff_cache/
# pyright: config lives in pyrightconfig.json (committed); no cache dir by default

# --- Gradio -------------------------------------------------------------------
gradio_cached_examples/
.gradio/

# --- Runtime data (SQLite, user uploads, session state) ----------------------
# Commit schema/migration files; ignore live database files
data/
# Static reference data bundled with packages must be tracked
!packages/*/*/data/
*.db
*.db-shm
*.db-wal
*.sqlite3

# --- Vector store (ChromaDB local) -------------------------------------------
chroma_db/
.chroma/
chromadb_data/

# --- Generated images & AI outputs -------------------------------------------
generated_images/
outputs/
# Harness eval results are transient; scored reports go here
harness/results/
harness/outputs/

# --- Docker local overrides ---------------------------------------------------
# deploy/compose/ base files are committed; personal overrides are not
docker-compose.override.yml

# --- Logs ---------------------------------------------------------------------
logs/
*.log

# --- Jupyter (exploration notebooks) -----------------------------------------
.ipynb_checkpoints

# --- Documentation builds -----------------------------------------------------
docs/_build/
/site

# --- Model Context Protocol (MCP) servers & configuration ----
mcps/
playwright-mcp/
.playwright-mcp/
.mcp.json

# --- IDE — VS Code ------------------------------------------------------------
# Commit .vscode/extensions.json (recommended extensions) but not personal settings
.vscode/settings.json
.vscode/launch.json
.vscode/.ropeproject

# --- IDE — JetBrains ----------------------------------------------------------
.idea/
*.iml
*.iws

# --- OS artifacts -------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Misc Python tools --------------------------------------------------------
.pybuilder/
.pdm-python
.pdm-build/
tempCodeRunnerFile.py
.pypirc

# --- Claude agent instructions --------------------------------
.claude/

# --- pyenv (uncomment to commit the Python version pin) ----------------------
# .python-version
.claude/settings.local.json
