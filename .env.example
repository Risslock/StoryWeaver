# ============================================================
# StoryWeaver — Environment Configuration
# Copy to .env and edit. Never commit .env to source control.
# ============================================================

# --- Database ---
# SQLite (local default)
DATABASE_URL=sqlite+aiosqlite:///data/storyweaver.db
# Postgres (cloud M5+)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/storyweaver

# --- LLM provider ---
# Options: ollama | anthropic | openai | huggingface
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Anthropic (M5+)
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...

# OpenAI (M5+)
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...

# HuggingFace Inference API (free tier — https://huggingface.co/settings/tokens)
# LLM_PROVIDER=huggingface
# HF_API_KEY=hf_...

# --- Embeddings ---
# Options: ollama | huggingface
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
# HuggingFace embedding alternative (free, no GPU required):
# EMBEDDING_PROVIDER=huggingface
# EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
HF_API_KEY=

# --- Image generation ---
# Options: huggingface (default, free tier) | comfyui (local)
IMAGE_PROVIDER=huggingface
# Free-tier model: black-forest-labs/FLUX.1-schnell (high quality, fast)
# Other free options: stabilityai/stable-diffusion-xl-base-1.0, runwayml/stable-diffusion-v1-5
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
COMFYUI_URL=http://localhost:8188
# To use ComfyUI locally:
# IMAGE_PROVIDER=comfyui

# --- Knowledge Q&A (RAG) ---
# Ollama model used to embed chunks and queries (must be pulled: ollama pull nomic-embed-text)
KNOWLEDGE_EMBED_MODEL=nomic-embed-text
# Small/fast Ollama model used for chunk enrichment during ingestion (ollama pull llama3.2)
KNOWLEDGE_ENRICH_MODEL=llama3.2
# Larger Ollama model used for Q&A answers, query expansion, and re-ranking
KNOWLEDGE_LLM_MODEL=llama3.1
# Chunks per enrichment LLM call — keep small (3-10) for local memory-constrained setups;
# batches run in parallel via asyncio.gather so total time ≈ slowest single call
KNOWLEDGE_ENRICH_BATCH_SIZE=5
# Maximum tokens per chunk (heading-based splits are further capped to this size)
KNOWLEDGE_MAX_CHUNK_TOKENS=800
# Token overlap prepended to each chunk from the tail of the previous one
KNOWLEDGE_CHUNK_OVERLAP_TOKENS=50
# Number of chunks returned to the answer prompt after re-ranking
KNOWLEDGE_TOP_K=8
# Reciprocal Rank Fusion constant k (higher = smoother score distribution)
KNOWLEDGE_RRF_K=60
# Number of alternative query phrasings generated for multi-query retrieval
KNOWLEDGE_EXPANSION_COUNT=3

# --- App ---
LOG_LEVEL=INFO
MAX_TWIN_TURNS=20
