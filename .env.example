# ============================================================
# StoryWeaver — Environment Configuration
# Copy to .env and fill in your values.
# Never commit .env to source control — it contains secrets.
#
# All variables have code-level defaults defined in packages/core/core/config.py.
# Values shown here are the recommended settings for local development.
# Omitting a variable entirely falls back to the code-level default.
# ============================================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///data/storyweaver.db
# PostgreSQL (cloud):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/storyweaver

# ── App-wide LLM (twins, story generation, character builder) ─────────────────
LLM_PROVIDER=ollama                      # ollama | anthropic | openai | huggingface
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Cloud alternatives (comment out Ollama lines above):
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...

# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...

# LLM_PROVIDER=huggingface               # uses HF_API_KEY below

# ── HuggingFace (shared key for LLM, embeddings, images, and knowledge) ───────
# Required when any provider is set to "huggingface".
# Get your token at: https://huggingface.co/settings/tokens
HF_API_KEY=hf_...

# ── App-wide Embeddings (twin memory, character analysis) ─────────────────────
EMBEDDING_PROVIDER=ollama                # ollama | huggingface
EMBEDDING_MODEL=nomic-embed-text
# HuggingFace alternative:
# EMBEDDING_PROVIDER=huggingface
# EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# ── Image Generation ──────────────────────────────────────────────────────────
IMAGE_PROVIDER=huggingface               # huggingface | comfyui
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# Other free HF options: stabilityai/stable-diffusion-xl-base-1.0
COMFYUI_URL=http://localhost:8188        # only used when IMAGE_PROVIDER=comfyui

# ── Knowledge Pipeline — Provider Selection ────────────────────────────────────
# Controls which backend handles chunk enrichment LLM calls and embeddings.
# Both must be set to the same provider family unless you explicitly mix backends.
KNOWLEDGE_ENRICH_PROVIDER=ollama         # ollama | huggingface
KNOWLEDGE_EMBED_PROVIDER=ollama          # ollama | huggingface

# ── Knowledge Pipeline — Models ────────────────────────────────────────────────
# Ollama (local, default):
KNOWLEDGE_EMBED_MODEL=nomic-embed-text   # pull: ollama pull nomic-embed-text
KNOWLEDGE_ENRICH_MODEL=llama3.2          # small/fast model for chunk enrichment during ingestion
KNOWLEDGE_LLM_MODEL=llama3.1             # larger model for Q&A, query expansion, and re-ranking

# HuggingFace alternatives (set KNOWLEDGE_*_PROVIDER=huggingface and swap models):
# KNOWLEDGE_ENRICH_MODEL=mistralai/Mistral-7B-Instruct-v0.3
# KNOWLEDGE_EMBED_MODEL=BAAI/bge-m3                              # 1024-dim, strong multilingual
# KNOWLEDGE_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2  # 384-dim, confirmed free serverless
# KNOWLEDGE_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5           # 768-dim (note: different ID from Ollama's nomic-embed-text)

# ── Knowledge Pipeline — Docling Extraction ───────────────────────────────────
# Active when extraction_mode="docling" (recommended default for PDFs).
# Docling downloads layout ML models (~1-2 GB) on first run to ~/.cache/docling.
KNOWLEDGE_DOCLING_PAGE_BATCH_SIZE=10     # pages processed per batch; lower on ≤16 GB RAM

# ── Knowledge Pipeline — Ingestion ────────────────────────────────────────────
KNOWLEDGE_ENRICH_BATCH_SIZE=5            # chunks sent per enrichment LLM call (3–10 recommended)

# Chunking strategy — applies to legacy text/vision extraction paths only.
# The docling path always uses HybridChunker regardless of this setting.
#   heading  — fast, structure-preserving; best for well-formatted Markdown
#   semantic — embedding-similarity breakpoints; best for dense prose
#   agentic  — LLM proposition-boundary detection; highest quality, slowest
KNOWLEDGE_CHUNKING_STRATEGY=heading

KNOWLEDGE_MAX_CHUNK_TOKENS=2000          # target ceiling (≈4 chars/token); soft limit for chunkers
KNOWLEDGE_CHUNK_OVERLAP_TOKENS=200       # overlap between adjacent chunks (heading/agentic paths)
KNOWLEDGE_MIN_CHUNK_CHARS=150            # stubs shorter than this are merged into their neighbour
KNOWLEDGE_MAX_CHUNK_CHARS=15000          # chunks larger than this are re-split by the active chunker

# Pages scanned for front-matter removal (cover pages, copyright, blank TOC).
# Increase for books with long preliminary sections; set to 0 to disable.
KNOWLEDGE_CLEANING_FRONTMATTER_PAGES=10

# ── Knowledge Pipeline — Semantic Chunker Tuning ──────────────────────────────
# Only applies when KNOWLEDGE_CHUNKING_STRATEGY=semantic.
KNOWLEDGE_SEMANTIC_BREAKPOINT_PERCENTILE=95   # cosine-similarity percentile cutoff; lower = fewer, larger chunks
KNOWLEDGE_SEMANTIC_MIN_CHUNK_TOKENS=50        # chunks below this are merged with their neighbour

# ── Knowledge Pipeline — Agentic Chunker Tuning ────────────────────────────────
# Only applies when KNOWLEDGE_CHUNKING_STRATEGY=agentic (docling_text/text/vision paths).
# These defaults are tuned for deeply nested RPG rulebooks.
KNOWLEDGE_AGENTIC_BATCH_SECTIONS=5       # heading sections sent to the LLM per call;
                                          # higher = more cross-section merge opportunities, more tokens
KNOWLEDGE_AGENTIC_SKIP_TOKENS=200        # sections shorter than this bypass the LLM entirely;
                                          # lower catches more short sub-sections for potential merging
KNOWLEDGE_AGENTIC_PROSE_THRESHOLD=0.4    # sections with fewer than this fraction of prose lines
                                          # are treated as appendages and merged into the preceding section

# Optional: replace the built-in RPG-tuned system/user prompts with your own.
# Leave blank (or omit) to use the built-in defaults.
# Useful when chunking non-RPG document types (legal, academic, technical manuals).
# KNOWLEDGE_AGENTIC_SYSTEM_PROMPT=You are an expert document chunker. Produce self-contained, retrievable chunks.
# KNOWLEDGE_AGENTIC_USER_PROMPT_PREFIX=<your custom instruction block; {sections_text} is appended automatically>

# ── Knowledge Pipeline — Retrieval ────────────────────────────────────────────
KNOWLEDGE_TOP_K=10                       # chunks returned to the answer LLM after RRF re-ranking
KNOWLEDGE_RRF_K=30                       # RRF smoothing constant; higher = more uniform score distribution
KNOWLEDGE_EXPANSION_COUNT=3              # extra query phrasings generated for multi-query retrieval;
                                          # set to 0 to disable query expansion (faster but lower recall)

# ── Knowledge Pipeline — Vision Path (extraction_mode=vision) ─────────────────
# Only needed when vision extraction is selected in the GM UI.
# Requires an Ollama vision model to be running locally.
# KNOWLEDGE_VISION_MODEL=blaifa/Nanonets-OCR-s     # pull: ollama pull blaifa/Nanonets-OCR-s
# KNOWLEDGE_VISION_TIMEOUT_SECS=120                # seconds before a page OCR call is aborted
# KNOWLEDGE_VISION_MAX_RETRIES=1                   # retries on timeout before marking page as failed

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR | CRITICAL
MAX_TWIN_TURNS=20
