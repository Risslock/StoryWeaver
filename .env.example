# ============================================================
# StoryWeaver — Environment Configuration
# Copy to .env and edit. Never commit .env to source control.
# ============================================================

# --- LLM provider ---
# Options: ollama | anthropic | openai | huggingface
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic (M5+)
# LLM_API_KEY=sk-ant-...

# OpenAI (M5+)
# LLM_API_KEY=sk-...

# HuggingFace Inference API (free tier — https://huggingface.co/settings/tokens)
# LLM_PROVIDER=huggingface
# HF_API_KEY=hf_...
# HF_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# --- Embeddings ---
# Options: ollama | huggingface
EMBED_PROVIDER=ollama
EMBED_MODEL=nomic-embed-text
# HuggingFace embedding alternative (free, no GPU required):
# EMBED_PROVIDER=huggingface
# EMBED_MODEL=BAAI/bge-base-en-v1.5

# --- RAG / Vector store ---
# Options: chroma | pgvector
VECTOR_STORE=chroma
CHROMA_PATH=./data/chroma
# pgvector (cloud only — M5+):
# VECTOR_STORE=pgvector
# PGVECTOR_URL=postgresql://user:password@localhost:5432/storyweaver

# --- Image generation ---
# Options: local | cloud
IMAGE_PROVIDER=local
# Options (local): comfyui | sd-webui
IMAGE_LOCAL_BACKEND=comfyui
COMFYUI_BASE_URL=http://localhost:8188
# IMAGE_CLOUD_API_KEY=...

# --- Storage ---
# Options: local | cloud
DB_MODE=local
SQLITE_PATH=./data/storyweaver.db
# Cloud (M5+):
# DATABASE_URL=postgresql://user:password@localhost:5432/storyweaver

# --- App ---
LOG_LEVEL=INFO
